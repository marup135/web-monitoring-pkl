generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institution {
  id        String          @id @default(uuid())
  name      String          @db.VarChar(255)
  code      String          @unique @db.VarChar(50)
  type      InstitutionType @default(OTHER)
  logo      String?
  address   String?
  phone     String?         @db.VarChar(50)
  website   String?         @db.VarChar(255)
  email     String?         @db.VarChar(255)
  status    String          @default("PENDING") @db.VarChar(20)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  classes   Kelas[]         @relation("InstitutionClasses")
  companies Perusahaan[]    @relation("InstitutionCompanies")
  users     User[]          @relation("UserInstitution")
}

model User {
  id                    String         @id @default(uuid())
  username              String         @unique @db.VarChar(255)
  password              String         @db.VarChar(255)
  name                  String         @db.VarChar(255)
  role                  String         @db.VarChar(50)
  company               String?        @db.VarChar(255)
  nisn                  String?        @db.VarChar(50)
  school                String         @default("SMKN 1 BOJONG") @db.VarChar(255)
  createdAt             DateTime       @default(now())
  classId               String?        @db.VarChar(255)
  companyId             String?        @db.VarChar(255)
  boardBackground       String?
  email                 String?        @unique @db.VarChar(255)
  jabatan               String?        @db.VarChar(100)
  nip                   String?        @db.VarChar(50)
  status                String         @default("ACTIVE") @db.VarChar(20)
  companyEmail          String?        @db.VarChar(255)
  companyName           String?        @db.VarChar(255)
  employeeId            String?        @db.VarChar(50)
  jobTitle              String?        @db.VarChar(100)
  profileImage          String?
  lastAfternoonReminder String?        @db.VarChar(10)
  lastMorningReminder   String?        @db.VarChar(10)
  institutionId         String?        @db.VarChar(255)
  faceDescriptor        String?
  writtenNotes          AdvisorNote[]  @relation("AdvisorNotes")
  advisorNotes          AdvisorNote[]  @relation("StudentNotes")
  attendances           Attendance[]   @relation("UserAttendances")
  cards                 Card[]         @relation("StudentCards")
  notifications         Notification[] @relation("UserNotifications")
  class                 Kelas?         @relation("StudentClass", fields: [classId], references: [id])
  perusahaan            Perusahaan?    @relation("StudentCompany", fields: [companyId], references: [id])
  institution           Institution?   @relation("UserInstitution", fields: [institutionId], references: [id])
  classes               Kelas[]        @relation("AdvisorClasses")
  collaboratingCards    Card[]         @relation("CardCollaborators")
  companies             Perusahaan[]   @relation("MentorCompanies")
}

model Card {
  id                        String        @id @default(uuid())
  title                     String        @db.VarChar(255)
  description               String
  columnId                  String        @default("rencana")
  category                  String        @default("Coding")
  startTime                 String        @default("")
  endTime                   String        @default("")
  dueDate                   String
  createdAt                 DateTime      @default(now())
  scoreMentor               Int?
  scoreMentorDiscipline     Int?
  scoreMentorSkill          Int?
  scoreMentorAttitude       Int?
  feedbackMentor            String?
  scoreAdvisor              Int?
  scoreAdvisorDiscipline    Int?
  scoreAdvisorReport        Int?
  scoreAdvisorCommunication Int?
  feedbackAdvisor           String?
  attachmentsJson           String?
  studentId                 String
  collaboratorsCanEdit      Boolean       @default(false)
  student                   User          @relation("StudentCards", fields: [studentId], references: [id], onDelete: Cascade)
  comments                  Comment[]
  history                   HistoryItem[]
  collaborators             User[]        @relation("CardCollaborators")

  @@index([studentId])
}

model Comment {
  id        String   @id @default(uuid())
  userName  String
  role      String
  text      String
  createdAt DateTime @default(now())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model HistoryItem {
  id        String   @id @default(uuid())
  text      String
  createdAt DateTime @default(now())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model AdvisorNote {
  id          String   @id @default(uuid())
  advisorName String
  text        String
  createdAt   DateTime @default(now())
  studentId   String
  advisorId   String
  advisor     User     @relation("AdvisorNotes", fields: [advisorId], references: [id], onDelete: Cascade)
  student     User     @relation("StudentNotes", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([advisorId])
}

model Kelas {
  id            String       @id @default(uuid())
  name          String       @db.VarChar(255)
  createdAt     DateTime     @default(now())
  institutionId String?      @db.VarChar(255)
  institution   Institution? @relation("InstitutionClasses", fields: [institutionId], references: [id])
  students      User[]       @relation("StudentClass")
  advisors      User[]       @relation("AdvisorClasses")

  @@unique([name, institutionId])
}

model Perusahaan {
  id            String       @id @default(uuid())
  name          String       @db.VarChar(255)
  createdAt     DateTime     @default(now())
  institutionId String?      @db.VarChar(255)
  institution   Institution? @relation("InstitutionCompanies", fields: [institutionId], references: [id])
  students      User[]       @relation("StudentCompany")
  mentors       User[]       @relation("MentorCompanies")

  @@unique([name, institutionId])
}

model Attendance {
  id            String   @id @default(uuid())
  date          String
  status        String   @default("NOT_CHECKED_IN") @db.VarChar(50)
  createdAt     DateTime @default(now())
  checkIn       String?
  checkOut      String?
  updatedAt     DateTime @updatedAt
  userId        String
  checkInLat    Float?
  checkInLng    Float?
  checkInPhoto  String?
  checkOutLat   Float?
  checkOutLng   Float?
  checkOutPhoto String?
  activityNotes String?
  user          User     @relation("UserAttendances", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String   @db.VarChar(255)
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("INFO") @db.VarChar(50)
  createdAt DateTime @default(now())
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum InstitutionType {
  SCHOOL
  UNIVERSITY
  TRAINING_CENTER
  COMPANY
  OTHER
}
